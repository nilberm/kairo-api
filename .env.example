# Banco de dados (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=kairo

# Usuário padrão (UUID) usado pela API até haver login
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# Autenticação JWT (obrigatório em produção)
JWT_SECRET=altere-isso-em-producao-use-uma-chave-longa-e-aleatoria

# Seed: senha do usuário padrão (default@kairo.app) criado pelo seed
# SEED_DEFAULT_PASSWORD=changeme

# Opcional
PORT=4000
# CORS: origens permitidas (separadas por vírgula). Inclua produção e localhost para dev local.
# Ex.: WEB_ORIGIN=https://seu-app.vercel.app,http://localhost:3000,http://127.0.0.1:3000
WEB_ORIGIN=http://localhost:3000
